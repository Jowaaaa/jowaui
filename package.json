{
  "name": "jowaui",
  "version": "0.1.0",
  "description": "Zero-dependency React UI component library built on CSS custom properties",
  "private": false,
  "license": "MIT",
  "author": "Job van der Wal",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jowaaaa/jowaui"
  },
  "homepage": "https://jowaui.jobvanderwal.dev/?path=/story/introduction--docs",
  "keywords": [
    "react",
    "ui",
    "components",
    "css-custom-properties",
    "design-system",
    "zero-dependencies",
    "oklch",
    "dark-mode"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-themes": "^8.6.18",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "react": "^18",
    "react-dom": "^18",
    "storybook": "^8.6.14",
    "tsup": "^8.5.1",
    "typescript": "^5"
  }
}
